generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Configurable Tariffs
model Tariff {
  id              String      @id @default(uuid())
  name            String      @unique // e.g., "Standard Residential Tariff"
  isActive        Boolean     @default(false)
  version         Int         @default(1)
  effectiveFrom   DateTime    @default(now())
  effectiveTo     DateTime?
  changeReason    String?
  penaltyRate     Float       @default(0)
  reconnectionFee Float       @default(0)
  createdById     String?
  createdBy       User?       @relation("CreatedTariffs", fields: [createdById], references: [id])
  
  minimumCharge   Float       // Base fee for 0 usage (e.g., 25)
  minimumUsage    Float       // Usage covered by base fee (e.g., 1 cu.m)
  
  installationFee Float       // One-time fee (e.g., 3000)
  
  tiers           TariffTier[]
  bills           Bill[]
  auditEvents     TariffAuditEvent[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([effectiveFrom(sort: Desc)])
  @@index([isActive, effectiveFrom(sort: Desc)])
}

model TariffTier {
  id          String   @id @default(uuid())
  tariffId    String
  tariff      Tariff   @relation(fields: [tariffId], references: [id])
  
  minVolume   Float    // Lower bound of tier (inclusive)
  maxVolume   Float?   // Upper bound of tier (null = no limit/22+)
  ratePerCuM  Float    // Cost per cubic meter in this tier
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// System Users (Staff)
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  passwordHash String
  mustChangePassword Boolean @default(false)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecretCiphertext String?
  twoFactorPendingSecretCiphertext String?
  twoFactorRecoveryCodeHashes String[] @default([])
  twoFactorEnabledAt DateTime?
  twoFactorLastVerifiedAt DateTime?
  role      Role     @default(VIEWER)
  isActive  Boolean  @default(true)
  failedSignInCount Int @default(0)
  lockedUntil DateTime?
  lastFailedSignInAt DateTime?
  lastLoginAt DateTime?

  readings  Reading[] // Meter readings performed by this user (if METER_READER)
  createdTariffs Tariff[] @relation("CreatedTariffs")
  tariffAuditEvents TariffAuditEvent[] @relation("TariffAuditEventActor")
  recordedPayments Payment[] @relation("RecordedPayments")
  receivableFollowUpUpdates Bill[] @relation("ReceivableFollowUpUpdatedBy")
  customerStatusUpdates Customer[] @relation("CustomerStatusUpdatedBy")
  triggeredNotifications NotificationLog[] @relation("TriggeredNotifications")
  loginAttempts AdminLoginAttempt[] @relation("AdminLoginAttemptUser")
  adminManagementEvents AuthAdminManagementEvent[] @relation("AdminManagementEventActor")
  adminManagementTargets AuthAdminManagementEvent[] @relation("AdminManagementEventTarget")
  backupSnapshotsCreated BackupSnapshot[] @relation("BackupSnapshotCreatedBy")
  finalizedBillingCycles BillingCycle[] @relation("BillingCycleFinalizedBy")
  reopenedBillingCycles BillingCycle[] @relation("BillingCycleReopenedBy")
  closedBillingCycles BillingCycle[] @relation("BillingCycleClosedBy")
  billingCycleEvents BillingCycleEvent[] @relation("BillingCycleEventActor")
  createdPrintBatches BillPrintBatch[] @relation("BillPrintBatchCreatedBy")
  assignedPrintBatches BillPrintBatch[] @relation("BillPrintBatchAssignedTo")
  printedPrintBatches BillPrintBatch[] @relation("BillPrintBatchPrintedBy")
  distributedPrintBatches BillPrintBatch[] @relation("BillPrintBatchDistributedBy")
  returnedPrintBatches BillPrintBatch[] @relation("BillPrintBatchReturnedBy")
  failedDeliveryPrintBatches BillPrintBatch[] @relation("BillPrintBatchFailedBy")
  staffRouteAssignments StaffRouteAssignment[]
  reportedComplaints Complaint[] @relation("ComplaintReportedBy")
  resolvedComplaints Complaint[] @relation("ComplaintResolvedBy")
  createdLeakReports LeakReport[] @relation("LeakReportCreatedBy")
  resolvedLeakReports LeakReport[] @relation("LeakReportResolvedBy")
  createdFieldWorkOrders FieldWorkOrder[] @relation("FieldWorkOrderCreatedBy")
  assignedFieldWorkOrders FieldWorkOrder[] @relation("FieldWorkOrderAssignedTo")
  completedFieldWorkOrders FieldWorkOrder[] @relation("FieldWorkOrderCompletedBy")
  uploadedFieldWorkProofs FieldWorkProof[] @relation("FieldWorkProofUploadedBy")
  recordedRepairHistory RepairHistory[] @relation("RepairHistoryRecordedBy")
  recordedMeterReplacements MeterReplacementHistory[] @relation("MeterReplacementRecordedBy")
  finalizedBills Bill[] @relation("BillFinalizedBy")
  printedBills Bill[] @relation("BillPrintedBy")
  distributedBills Bill[] @relation("BillDistributedBy")
  returnedBills Bill[] @relation("BillReturnedBy")
  failedDeliveryBills Bill[] @relation("BillFailedBy")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CASHIER
  BILLING
  METER_READER
  TECHNICIAN
  VIEWER
}

// Customers (Residential)
model Customer {
  id            String   @id @default(uuid())
  accountNumber String   @unique // Generated account number
  name          String
  address       String
  contactNumber String?
  email         String?
  status        CustomerStatus @default(ACTIVE)
  statusNote    String?
  statusUpdatedAt DateTime?
  statusUpdatedById String?
  statusUpdatedBy User? @relation("CustomerStatusUpdatedBy", fields: [statusUpdatedById], references: [id])
  
  meters        Meter[]
  receivedMeterTransfers MeterHolderTransfer[] @relation("MeterHolderTransferToCustomer")
  releasedMeterTransfers MeterHolderTransfer[] @relation("MeterHolderTransferFromCustomer")
  bills         Bill[]
  notifications NotificationLog[]
  complaints    Complaint[]
  leakReports   LeakReport[]
  repairHistory RepairHistory[]
  meterReplacementHistory MeterReplacementHistory[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  DISCONNECTED
}

// Water Meters
model Meter {
  id            String   @id @default(uuid())
  meterNumber   String   @unique
  installDate   DateTime
  status        MeterStatus @default(ACTIVE)
  
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  serviceZoneId String?
  serviceZone   ServiceZone? @relation(fields: [serviceZoneId], references: [id])
  serviceRouteId String?
  serviceRoute  ServiceRoute? @relation(fields: [serviceRouteId], references: [id])
  
  readings      Reading[]
  holderTransfers MeterHolderTransfer[]
  complaints      Complaint[]
  leakReports     LeakReport[]
  repairHistory   RepairHistory[]
  replacedMeterHistory MeterReplacementHistory[] @relation("MeterReplacementHistoryFrom")
  installedReplacementHistory MeterReplacementHistory[] @relation("MeterReplacementHistoryTo")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([serviceZoneId])
  @@index([serviceRouteId])
}

enum MeterStatus {
  ACTIVE
  DEFECTIVE
  REPLACED
}

model MeterHolderTransfer {
  id                 String    @id @default(uuid())
  meterId            String
  meter              Meter     @relation(fields: [meterId], references: [id])
  fromCustomerId     String?
  fromCustomer       Customer? @relation("MeterHolderTransferFromCustomer", fields: [fromCustomerId], references: [id])
  toCustomerId       String
  toCustomer         Customer   @relation("MeterHolderTransferToCustomer", fields: [toCustomerId], references: [id])
  effectiveDate      DateTime
  transferReading    Float?
  reason             String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([meterId, effectiveDate(sort: Desc)])
  @@index([toCustomerId])
  @@index([fromCustomerId])
}

// Meter Readings
model Reading {
  id              String   @id @default(uuid())
  meterId         String
  meter           Meter    @relation(fields: [meterId], references: [id])
  
  readerId        String
  reader          User     @relation(fields: [readerId], references: [id])
  
  readingDate     DateTime @default(now())
  previousReading Float
  currentReading  Float
  consumption     Float    // Auto-calculated
  
  status          ReadingStatus @default(PENDING_REVIEW)
  
  bill            Bill?    // The bill generated for this reading
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum ReadingStatus {
  PENDING_REVIEW
  APPROVED
  FLAGGED
}

model BillingCycle {
  id                           String             @id @default(uuid())
  periodKey                    String             @unique
  billingPeriodLabel           String             @unique
  status                       BillingCycleStatus @default(OPEN)
  checklistReviewCompleted     Boolean            @default(false)
  checklistReceivablesVerified Boolean            @default(false)
  checklistPrintReady          Boolean            @default(false)
  checklistDistributionReady   Boolean            @default(false)
  checklistMonthEndLocked      Boolean            @default(false)
  closedAt                     DateTime?
  closedById                   String?
  closedBy                     User?              @relation("BillingCycleClosedBy", fields: [closedById], references: [id])
  reopenedAt                   DateTime?
  reopenedById                 String?
  reopenedBy                   User?              @relation("BillingCycleReopenedBy", fields: [reopenedById], references: [id])
  finalizedAt                  DateTime?
  finalizedById                String?
  finalizedBy                  User?              @relation("BillingCycleFinalizedBy", fields: [finalizedById], references: [id])
  bills                        Bill[]
  printBatches                 BillPrintBatch[]
  events                       BillingCycleEvent[]
  createdAt                    DateTime           @default(now())
  updatedAt                    DateTime           @updatedAt

  @@index([status])
}

enum BillingCycleStatus {
  OPEN
  CLOSED
  FINALIZED
}

model BillPrintBatch {
  id              String              @id @default(uuid())
  billingCycleId  String
  billingCycle    BillingCycle        @relation(fields: [billingCycleId], references: [id])
  label           String
  grouping        BillPrintGrouping   @default(ALL)
  groupingValue   String?
  serviceZoneId   String?
  serviceZone     ServiceZone?        @relation(fields: [serviceZoneId], references: [id])
  serviceRouteId  String?
  serviceRoute    ServiceRoute?       @relation(fields: [serviceRouteId], references: [id])
  status          BillPrintBatchStatus @default(DRAFT)
  notes           String?
  assignedToId    String?
  assignedTo      User?               @relation("BillPrintBatchAssignedTo", fields: [assignedToId], references: [id])
  createdById     String
  createdBy       User                @relation("BillPrintBatchCreatedBy", fields: [createdById], references: [id])
  printedAt       DateTime?
  printedById     String?
  printedBy       User?               @relation("BillPrintBatchPrintedBy", fields: [printedById], references: [id])
  distributedAt   DateTime?
  distributedById String?
  distributedBy   User?               @relation("BillPrintBatchDistributedBy", fields: [distributedById], references: [id])
  returnedAt      DateTime?
  returnedById    String?
  returnedBy      User?               @relation("BillPrintBatchReturnedBy", fields: [returnedById], references: [id])
  failedDeliveryAt DateTime?
  failedDeliveryById String?
  failedDeliveryBy User?              @relation("BillPrintBatchFailedBy", fields: [failedDeliveryById], references: [id])
  bills           Bill[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([billingCycleId, status])
  @@index([serviceZoneId])
  @@index([serviceRouteId])
}

enum BillPrintGrouping {
  ALL
  ZONE
  ROUTE
  PUROK
  MANUAL
}

enum BillPrintBatchStatus {
  DRAFT
  PRINTED
  DISTRIBUTED
  RETURNED
  FAILED_DELIVERY
}

model BillingCycleEvent {
  id             String                @id @default(uuid())
  billingCycleId String
  billingCycle   BillingCycle          @relation(fields: [billingCycleId], references: [id])
  type           BillingCycleEventType
  actorId        String
  actor          User                  @relation("BillingCycleEventActor", fields: [actorId], references: [id])
  note           String?
  billId         String?
  billPrintBatchId String?
  occurredAt     DateTime              @default(now())
  createdAt      DateTime              @default(now())

  @@index([billingCycleId, occurredAt(sort: Desc)])
  @@index([type])
}

enum BillingCycleEventType {
  CYCLE_CREATED
  CYCLE_CLOSED
  CYCLE_REOPENED
  CYCLE_FINALIZED
  BILLS_REGENERATED
  PRINT_BATCH_CREATED
  PRINT_BATCH_PRINTED
  PRINT_BATCH_DISTRIBUTED
  PRINT_BATCH_RETURNED
  PRINT_BATCH_FAILED_DELIVERY
  SINGLE_BILL_REPRINTED
  CHECKLIST_UPDATED
}

// Bills generated from Readings
model Bill {
  id            String   @id @default(uuid())
  billingPeriod String   // e.g., "Oct 2026"
  billingCycleId String?
  billingCycle  BillingCycle? @relation(fields: [billingCycleId], references: [id])
  tariffId      String?
  tariff        Tariff?  @relation(fields: [tariffId], references: [id])
  dueDate       DateTime
  
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  
  readingId     String   @unique
  reading       Reading  @relation(fields: [readingId], references: [id])
  
  usageAmount   Float
  totalCharges  Float
  status        BillStatus @default(UNPAID)
  lifecycleStatus BillLifecycleStatus @default(DRAFT)
  finalizedAt   DateTime?
  finalizedById String?
  finalizedBy   User? @relation("BillFinalizedBy", fields: [finalizedById], references: [id])
  followUpStatus ReceivableFollowUpStatus @default(CURRENT)
  followUpStatusUpdatedAt DateTime?
  followUpNote  String?
  followUpUpdatedById String?
  followUpUpdatedBy User? @relation("ReceivableFollowUpUpdatedBy", fields: [followUpUpdatedById], references: [id])
  printBatchId  String?
  printBatch    BillPrintBatch? @relation(fields: [printBatchId], references: [id])
  distributionStatus BillDistributionStatus @default(PENDING_PRINT)
  printedAt     DateTime?
  printedById   String?
  printedBy     User? @relation("BillPrintedBy", fields: [printedById], references: [id])
  distributedAt DateTime?
  distributedById String?
  distributedBy User? @relation("BillDistributedBy", fields: [distributedById], references: [id])
  returnedAt    DateTime?
  returnedById  String?
  returnedBy    User? @relation("BillReturnedBy", fields: [returnedById], references: [id])
  failedDeliveryAt DateTime?
  failedDeliveryById String?
  failedDeliveryBy User? @relation("BillFailedBy", fields: [failedDeliveryById], references: [id])
  deliveryNote  String?
  reprintCount  Int @default(0)
  
  payments      Payment[]
  notifications NotificationLog[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([billingCycleId, lifecycleStatus])
  @@index([distributionStatus])
  @@index([printBatchId])
  @@index([tariffId])
}

enum BillLifecycleStatus {
  DRAFT
  FINALIZED
}

enum BillDistributionStatus {
  PENDING_PRINT
  PRINTED
  DISTRIBUTED
  RETURNED
  FAILED_DELIVERY
}

enum BillStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum ReceivableFollowUpStatus {
  CURRENT
  REMINDER_SENT
  FINAL_NOTICE_SENT
  DISCONNECTION_REVIEW
  DISCONNECTED
  RESOLVED
}

model NotificationLog {
  id            String             @id @default(uuid())
  customerId    String
  customer      Customer           @relation(fields: [customerId], references: [id])
  billId        String?
  bill          Bill?              @relation(fields: [billId], references: [id])
  channel       NotificationChannel
  template      NotificationTemplate
  status        NotificationStatus @default(PENDING)
  provider      String
  destination   String
  subject       String?
  message       String
  providerMessageId String?
  errorMessage  String?
  triggeredById String?
  triggeredBy   User?              @relation("TriggeredNotifications", fields: [triggeredById], references: [id])
  sentAt        DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([customerId])
  @@index([billId])
  @@index([status])
  @@index([channel])
  @@index([template])
}

enum NotificationChannel {
  EMAIL
  SMS
  PRINT
}

enum NotificationTemplate {
  BILLING_REMINDER
  FOLLOW_UP_REMINDER
  FINAL_NOTICE
  DISCONNECTION
  REINSTATEMENT
  SERVICE_INTERRUPTION
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model TariffAuditEvent {
  id        String               @id @default(uuid())
  tariffId   String
  tariff     Tariff              @relation(fields: [tariffId], references: [id])
  actorId    String?
  actor      User?               @relation("TariffAuditEventActor", fields: [actorId], references: [id])
  type       TariffAuditEventType
  note       String?
  createdAt  DateTime            @default(now())

  @@index([tariffId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
}

enum TariffAuditEventType {
  CREATED
  RETIRED
}

model AdminLoginAttempt {
  id            String                  @id @default(uuid())
  email         String
  userId        String?
  user          User?                   @relation("AdminLoginAttemptUser", fields: [userId], references: [id])
  status        AdminLoginAttemptStatus
  failureReason String?
  ipAddress     String?
  userAgent     String?
  attemptedAt   DateTime                @default(now())
  createdAt     DateTime                @default(now())

  @@index([email, attemptedAt(sort: Desc)])
  @@index([userId, attemptedAt(sort: Desc)])
  @@index([status, attemptedAt(sort: Desc)])
}

enum AdminLoginAttemptStatus {
  SUCCESS
  FAILED
  LOCKED_OUT
}

model AuthAdminManagementEvent {
  id            String                    @id @default(uuid())
  type          AuthAdminManagementEventType
  actorId       String
  actor         User                      @relation("AdminManagementEventActor", fields: [actorId], references: [id])
  targetUserId  String?
  targetUser    User?                     @relation("AdminManagementEventTarget", fields: [targetUserId], references: [id])
  actorEmail    String
  targetEmail   String
  detail        String
  occurredAt    DateTime                  @default(now())
  createdAt     DateTime                  @default(now())

  @@index([actorId, occurredAt(sort: Desc)])
  @@index([targetUserId, occurredAt(sort: Desc)])
  @@index([type, occurredAt(sort: Desc)])
}

enum AuthAdminManagementEventType {
  ADMIN_CREATED
  ROLE_CHANGED
  ACCOUNT_DEACTIVATED
  ACCOUNT_REACTIVATED
  LOCKOUT_CLEARED
  TEMPORARY_PASSWORD_SET
  OWN_PASSWORD_CHANGED
  TWO_FACTOR_ENABLED
  TWO_FACTOR_DISABLED
}

model BackupSnapshot {
  id               String               @id @default(uuid())
  snapshotMonth    String
  label            String
  provider         String               @default("SUPABASE")
  storageReference String
  status           BackupSnapshotStatus @default(RECORDED)
  notes            String?
  createdById      String
  createdBy        User                 @relation("BackupSnapshotCreatedBy", fields: [createdById], references: [id])
  recordedAt       DateTime             @default(now())
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([snapshotMonth, recordedAt(sort: Desc)])
  @@index([status, recordedAt(sort: Desc)])
}

enum BackupSnapshotStatus {
  RECORDED
  VERIFIED
  RESTORE_TESTED
  FAILED
}

model ServiceZone {
  id          String           @id @default(uuid())
  name        String           @unique
  code        String?          @unique
  description String?
  routes      ServiceRoute[]
  meters      Meter[]
  complaints  Complaint[]
  leakReports LeakReport[]
  repairHistory RepairHistory[]
  meterReplacementHistory MeterReplacementHistory[]
  printBatches BillPrintBatch[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([name])
}

model ServiceRoute {
  id           String                 @id @default(uuid())
  name         String
  code         String                 @unique
  description  String?
  zoneId       String
  zone         ServiceZone            @relation(fields: [zoneId], references: [id])
  meters       Meter[]
  complaints   Complaint[]
  leakReports  LeakReport[]
  repairHistory RepairHistory[]
  meterReplacementHistory MeterReplacementHistory[]
  assignments  StaffRouteAssignment[]
  printBatches BillPrintBatch[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@unique([zoneId, name])
  @@index([zoneId, name])
}

model StaffRouteAssignment {
  id             String              @id @default(uuid())
  userId         String
  user           User                @relation(fields: [userId], references: [id])
  serviceRouteId String
  serviceRoute   ServiceRoute        @relation(fields: [serviceRouteId], references: [id])
  responsibility RouteResponsibility
  isPrimary      Boolean             @default(true)
  assignedAt     DateTime            @default(now())
  releasedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([userId, serviceRouteId, responsibility])
  @@index([serviceRouteId, responsibility])
  @@index([userId, responsibility])
  @@index([releasedAt])
}

enum RouteResponsibility {
  METER_READING
  BILL_DISTRIBUTION
}

model Complaint {
  id             String          @id @default(uuid())
  summary        String
  detail         String?
  category       ComplaintCategory
  status         ComplaintStatus @default(OPEN)
  reportedAt     DateTime        @default(now())
  createdById    String
  createdBy      User            @relation("ComplaintReportedBy", fields: [createdById], references: [id])
  resolvedById   String?
  resolvedBy     User?           @relation("ComplaintResolvedBy", fields: [resolvedById], references: [id])
  resolvedAt     DateTime?
  customerId     String?
  customer       Customer?       @relation(fields: [customerId], references: [id])
  meterId        String?
  meter          Meter?          @relation(fields: [meterId], references: [id])
  serviceZoneId  String
  serviceZone    ServiceZone     @relation(fields: [serviceZoneId], references: [id])
  serviceRouteId String
  serviceRoute   ServiceRoute    @relation(fields: [serviceRouteId], references: [id])
  leakReport     LeakReport?
  workOrders     FieldWorkOrder[]
  repairHistory  RepairHistory[]
  meterReplacementHistory MeterReplacementHistory[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([serviceRouteId, reportedAt(sort: Desc)])
  @@index([serviceZoneId, reportedAt(sort: Desc)])
  @@index([status, reportedAt(sort: Desc)])
  @@index([category, reportedAt(sort: Desc)])
  @@index([customerId, reportedAt(sort: Desc)])
  @@index([meterId, reportedAt(sort: Desc)])
}

enum ComplaintCategory {
  LEAK
  NO_WATER
  LOW_PRESSURE
  BILLING_DISPUTE
  METER_DAMAGE
  OTHER
}

enum ComplaintStatus {
  OPEN
  RESOLVED
}

model LeakReport {
  id              String           @id @default(uuid())
  complaintId     String           @unique
  complaint       Complaint        @relation(fields: [complaintId], references: [id])
  summary         String
  detail          String?
  status          LeakReportStatus @default(OPEN)
  createdById     String
  createdBy       User             @relation("LeakReportCreatedBy", fields: [createdById], references: [id])
  resolvedById    String?
  resolvedBy      User?            @relation("LeakReportResolvedBy", fields: [resolvedById], references: [id])
  resolvedAt      DateTime?
  resolutionNotes String?
  customerId      String?
  customer        Customer?        @relation(fields: [customerId], references: [id])
  meterId         String?
  meter           Meter?           @relation(fields: [meterId], references: [id])
  serviceZoneId   String
  serviceZone     ServiceZone      @relation(fields: [serviceZoneId], references: [id])
  serviceRouteId  String
  serviceRoute    ServiceRoute     @relation(fields: [serviceRouteId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([serviceRouteId, createdAt(sort: Desc)])
  @@index([serviceZoneId, createdAt(sort: Desc)])
  @@index([meterId, createdAt(sort: Desc)])
  @@index([customerId, createdAt(sort: Desc)])
}

enum LeakReportStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED_NO_LEAK
}

model FieldWorkOrder {
  id              String            @id @default(uuid())
  complaintId     String
  complaint       Complaint         @relation(fields: [complaintId], references: [id])
  title           String
  detail          String?
  priority        WorkOrderPriority @default(MEDIUM)
  status          WorkOrderStatus   @default(OPEN)
  createdById     String
  createdBy       User              @relation("FieldWorkOrderCreatedBy", fields: [createdById], references: [id])
  assignedToId    String?
  assignedTo      User?             @relation("FieldWorkOrderAssignedTo", fields: [assignedToId], references: [id])
  scheduledFor    DateTime?
  acknowledgedAt  DateTime?
  completedById   String?
  completedBy     User?             @relation("FieldWorkOrderCompletedBy", fields: [completedById], references: [id])
  completedAt     DateTime?
  resolutionNotes String?
  fieldProofs     FieldWorkProof[]
  repairHistory   RepairHistory?
  meterReplacementHistory MeterReplacementHistory?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([complaintId, createdAt(sort: Desc)])
  @@index([assignedToId, status, createdAt(sort: Desc)])
  @@index([status, priority, createdAt(sort: Desc)])
}

model FieldWorkProof {
  id               String         @id @default(uuid())
  workOrderId      String
  workOrder        FieldWorkOrder @relation(fields: [workOrderId], references: [id])
  originalFilename String
  storagePath      String         @unique
  contentType      String
  fileSizeBytes    Int
  uploadedById     String
  uploadedBy       User           @relation("FieldWorkProofUploadedBy", fields: [uploadedById], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([workOrderId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model RepairHistory {
  id             String       @id @default(uuid())
  workOrderId    String       @unique
  workOrder      FieldWorkOrder @relation(fields: [workOrderId], references: [id])
  complaintId    String
  complaint      Complaint    @relation(fields: [complaintId], references: [id])
  repairSummary  String
  repairDetail   String?
  recordedById   String
  recordedBy     User         @relation("RepairHistoryRecordedBy", fields: [recordedById], references: [id])
  customerId     String?
  customer       Customer?    @relation(fields: [customerId], references: [id])
  meterId        String?
  meter          Meter?       @relation(fields: [meterId], references: [id])
  serviceZoneId  String
  serviceZone    ServiceZone  @relation(fields: [serviceZoneId], references: [id])
  serviceRouteId String
  serviceRoute   ServiceRoute @relation(fields: [serviceRouteId], references: [id])
  completedAt    DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([completedAt(sort: Desc)])
  @@index([meterId, completedAt(sort: Desc)])
  @@index([customerId, completedAt(sort: Desc)])
  @@index([serviceRouteId, completedAt(sort: Desc)])
  @@index([serviceZoneId, completedAt(sort: Desc)])
}

model MeterReplacementHistory {
  id                String         @id @default(uuid())
  workOrderId       String?        @unique
  workOrder         FieldWorkOrder? @relation(fields: [workOrderId], references: [id])
  complaintId       String?
  complaint         Complaint?     @relation(fields: [complaintId], references: [id])
  replacedMeterId   String
  replacedMeter     Meter          @relation("MeterReplacementHistoryFrom", fields: [replacedMeterId], references: [id])
  replacementMeterId String
  replacementMeter  Meter          @relation("MeterReplacementHistoryTo", fields: [replacementMeterId], references: [id])
  recordedById      String
  recordedBy        User           @relation("MeterReplacementRecordedBy", fields: [recordedById], references: [id])
  customerId        String?
  customer          Customer?      @relation(fields: [customerId], references: [id])
  serviceZoneId     String
  serviceZone       ServiceZone    @relation(fields: [serviceZoneId], references: [id])
  serviceRouteId    String
  serviceRoute      ServiceRoute   @relation(fields: [serviceRouteId], references: [id])
  finalReading      Float?
  replacementDate   DateTime
  reason            String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([replacementDate(sort: Desc)])
  @@index([replacedMeterId, replacementDate(sort: Desc)])
  @@index([replacementMeterId, replacementDate(sort: Desc)])
  @@index([customerId, replacementDate(sort: Desc)])
  @@index([serviceRouteId, replacementDate(sort: Desc)])
  @@index([serviceZoneId, replacementDate(sort: Desc)])
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkOrderStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Payments applied to Bills
model Payment {
  id            String   @id @default(uuid())
  receiptNumber String   @unique
  amount        Float
  paymentDate   DateTime @default(now())
  method        PaymentMethod
  referenceId   String?  // Xendit ref, check number, etc.
  balanceBefore Float
  balanceAfter  Float
  recordedById  String
  recordedBy    User     @relation("RecordedPayments", fields: [recordedById], references: [id])
  
  billId        String
  bill          Bill     @relation(fields: [billId], references: [id])
  
  status        PaymentStatus @default(COMPLETED)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  GCASH
  MAYA
  CARD
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}
